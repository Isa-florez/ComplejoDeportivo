@model ComplejoDeportivo.Models.Entities.EspacioDeportivo

<div class="topbar">
    <div class="page-title">Nuevo Espacio</div>
    <a href="/EspacioDeportivo" class="btn btn-gray">← Volver</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert-error">@ViewBag.Error</div>
}

<div class="card" style="max-width:500px;">
    <form method="post" action="/EspacioDeportivo/Create">
        <div class="form-group">
            <label>Nombre</label>
            <input type="text" name="Nombre" value="@Model?.Nombre" required />
        </div>
        <div class="form-group">
            <label>Tipo (fútbol, piscina, baloncesto...)</label>
            <input type="text" name="Tipo" value="@Model?.Tipo" required />
        </div>
        <div class="form-group">
            <label>Capacidad</label>
            <input type="number" name="Capacidad" value="@Model?.Capacidad" required />
        </div>
        <div style="display:flex;gap:10px;margin-top:8px;">
            <button type="submit" class="btn btn-green">Guardar</button>
            <a href="/EspacioDeportivo" class="btn btn-gray">Cancelar</a>
        </div>
    </form>
</div>