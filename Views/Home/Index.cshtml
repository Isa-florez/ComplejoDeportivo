@{
    ViewData["Title"] = "Inicio";
}

<div class="topbar">
    <div class="page-title">Panel de Control</div>
    <div style="font-size:13px;color:var(--muted);">Lunes, 27 Abril 2026</div>
</div>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">
    <div class="card" style="border-left:4px solid var(--green);">
        <div style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Usuarios registrados</div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:36px;line-height:1;">0</div>
    </div>
    <div class="card" style="border-left:4px solid var(--accent);">
        <div style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Espacios deportivos</div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:36px;line-height:1;">0</div>
    </div>
    <div class="card" style="border-left:4px solid #3b82f6;">
        <div style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Reservas activas</div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:36px;line-height:1;">0</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
    <a href="/Usuario" style="text-decoration:none;">
        <div class="card" style="overflow:hidden;padding:0;transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='none'">
            <div style="height:80px;background:linear-gradient(135deg,var(--green-dark),var(--green-light));display:flex;align-items:center;justify-content:center;font-size:36px;">👥</div>
            <div style="padding:16px;">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;margin-bottom:4px;">Usuarios</div>
                <div style="font-size:12px;color:var(--muted);">Registra y gestiona los usuarios del complejo.</div>
                <span style="display:inline-block;margin-top:10px;font-size:11px;font-weight:500;color:var(--green);border:1px solid var(--green);padding:4px 12px;border-radius:20px;">Ver usuarios →</span>
            </div>
        </div>
    </a>
    <a href="/EspacioDeportivo" style="text-decoration:none;">
        <div class="card" style="overflow:hidden;padding:0;transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='none'">
            <div style="height:80px;background:linear-gradient(135deg,#92400e,#d97706);display:flex;align-items:center;justify-content:center;font-size:36px;">🏟️</div>
            <div style="padding:16px;">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;margin-bottom:4px;">Espacios</div>
                <div style="font-size:12px;color:var(--muted);">Administra canchas, piscinas y espacios disponibles.</div>
                <span style="display:inline-block;margin-top:10px;font-size:11px;font-weight:500;color:#d97706;border:1px solid #d97706;padding:4px 12px;border-radius:20px;">Ver espacios →</span>
            </div>
        </div>
    </a>
    <a href="/Reserva/Create" style="text-decoration:none;">
        <div class="card" style="overflow:hidden;padding:0;transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='none'">
            <div style="height:80px;background:linear-gradient(135deg,#1e3a5f,#2563eb);display:flex;align-items:center;justify-content:center;font-size:36px;">📅</div>
            <div style="padding:16px;">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;margin-bottom:4px;">Reservas</div>
                <div style="font-size:12px;color:var(--muted);">Crea y gestiona reservas sin conflictos de horario.</div>
                <span style="display:inline-block;margin-top:10px;font-size:11px;font-weight:500;color:#2563eb;border:1px solid #2563eb;padding:4px 12px;border-radius:20px;">Nueva reserva →</span>
            </div>
        </div>
    </a>
</div>