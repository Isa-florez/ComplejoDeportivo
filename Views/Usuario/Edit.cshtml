@model ComplejoDeportivo.Models.Entities.Usuario

<div class="topbar">
    <div class="page-title">Editar Usuario</div>
    <a href="/Usuario" class="btn btn-gray">← Volver</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert-error">@ViewBag.Error</div>
}

<div class="card" style="max-width:500px;">
    <form method="post" action="/Usuario/Edit">
        <input type="hidden" name="Id" value="@Model.Id" />
        <div class="form-group">
            <label>Nombre</label>
            <input type="text" name="Nombre" value="@Model.Nombre" required />
        </div>
        <div class="form-group">
            <label>Documento</label>
            <input type="text" name="Documento" value="@Model.Documento" required />
        </div>
        <div class="form-group">
            <label>Teléfono</label>
            <input type="text" name="Telefono" value="@Model.Telefono" required />
        </div>
        <div class="form-group">
            <label>Email</label>
            <input type="email" name="Email" value="@Model.Email" required />
        </div>
        <div style="display:flex;gap:10px;margin-top:8px;">
            <button type="submit" class="btn btn-green">Guardar</button>
            <a href="/Usuario" class="btn btn-gray">Cancelar</a>
        </div>
    </form>
</div>